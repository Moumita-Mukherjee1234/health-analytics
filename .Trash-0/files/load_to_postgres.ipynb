import pandas as pd
from sqlalchemy import create_engine

# Update password
engine = create_engine("postgresql+psycopg2://postgres:Moumita%40123@localhost:5432/hospital_db")

def load_csv(table, path):
    df = pd.read_csv(path)
    df.to_sql(table, engine, if_exists='append', index=False)
    print(f"{table} loaded successfully")

load_csv("patients", "data/raw/patients.csv")
load_csv("doctors", "data/raw/doctors.csv")
load_csv("appointments", "data/raw/appointments.csv")
load_csv("treatments", "data/raw/treatments.csv")
load_csv("billing", "data/raw/billing.csv")